<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="28dp"
    android:gravity="center"
    android:background="#F0F4FF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🌍"
        android:textSize="64sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LinguaQuiz"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#3F51B5"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Apprends le Français et l'Anglais"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/etMail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:padding="14dp"
        android:background="@drawable/input_bg"
        android:drawableLeft="@drawable/baseline_mail_28"
        android:drawablePadding="8dp"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Mot de passe / Password"
        android:inputType="textPassword"
        android:padding="14dp"
        android:background="@drawable/input_bg"
        android:drawableLeft="@drawable/baseline_lock_28"
        android:drawablePadding="8dp"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/bLogin"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Se connecter / Sign In"
        android:textSize="16sp"
        android:backgroundTint="#3F51B5"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvRegister"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pas de compte ? S'inscrire / Register"
        android:textSize="15sp"
        android:textColor="#3F51B5"
        android:padding="8dp"/>

</LinearLayout>
